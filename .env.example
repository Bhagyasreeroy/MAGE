# ─── API Keys ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=...

# ─── Backend ─────────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=INFO
ENVIRONMENT=development

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_PORT=3000

# ─── Vector Store ────────────────────────────────────────────────────────────
VECTOR_STORE_BACKEND=chroma     # Options: chroma | faiss
FAISS_INDEX_PATH=./data/faiss_index
CHROMA_DB_PATH=./data/chroma_db
CHROMA_HOST=chromadb
CHROMA_PORT=8001

# ─── Data Pipeline ───────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=100
PROCESSING_ENGINE=pandas         # Options: pandas | spark | dask

# ─── Authentication / JWT ────────────────────────────────────────────────────
# Generate a secure key:  python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=CHANGE-ME-IN-PRODUCTION-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Database ────────────────────────────────────────────────────────────────
# For docker compose, the backend container overrides this to point at the
# `postgres` service — see docker-compose.yml. This value is used for running
# the backend natively (outside Docker), pointing at a local Postgres.
DATABASE_URL=postgresql+asyncpg://mage:mage@localhost:5432/mage
POSTGRES_USER=mage
POSTGRES_PASSWORD=mage
POSTGRES_DB=mage
POSTGRES_PORT=5432
