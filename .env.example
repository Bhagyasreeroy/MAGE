# ─── API Keys ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=...

# ─── Backend ─────────────────────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
LOG_LEVEL=INFO
ENVIRONMENT=development

# ─── Frontend ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
FRONTEND_PORT=3000

# ─── Vector Store ────────────────────────────────────────────────────────────
VECTOR_STORE_BACKEND=chroma     # Options: chroma | faiss
FAISS_INDEX_PATH=./data/faiss_index
CHROMA_DB_PATH=./data/chroma_db
CHROMA_HOST=chromadb
CHROMA_PORT=8001

# ─── Data Pipeline ───────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=100
PROCESSING_ENGINE=pandas         # Options: pandas | spark | dask
